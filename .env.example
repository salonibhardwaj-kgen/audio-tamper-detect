# ── Audio Tampering Detection — Environment Variables ─────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Google Gemini API key — used by the VLM noise-type identification component.
# Free tier: 20 requests/day. Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face access token — required to stream FLEURS / Rasa / IndicVoices / Vaani
# datasets from the Hub. Accept dataset terms at huggingface.co before use.
# Get token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Base directory override (optional).
# Defaults to the repository root. Override only if your datasets live elsewhere.
# NOISE_BASE_DIR=/path/to/audio-tamper-detect
